# PostgreSQL Database Configuration
SPRING_DATASOURCE_URL=postgresql://username:password@host:port/database
SPRING_DATASOURCE_USERNAME=your_database_user
SPRING_DATASOURCE_PASSWORD=your_database_password

# Hibernate Configuration
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect
SPRING_JPA_SHOW_SQL=false

# Server Configuration
SERVER_PORT=9090
SERVER_SERVLET_CONTEXT_PATH=/

# Application Name
SPRING_APPLICATION_NAME=Notes-Saver-App

# Frontend Configuration
REACT_APP_API_URL=http://localhost:9090
REACT_APP_API_TIMEOUT=5000

# Render Deployment Configuration (for production)
RENDER_DATABASE_URL=postgresql://username:password@host:port/database
RENDER_BACKEND_URL=https://your-backend-url.onrender.com
RENDER_FRONTEND_URL=https://your-frontend-url.onrender.com

# Environment
ENVIRONMENT=development
